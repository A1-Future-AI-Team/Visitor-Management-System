APP_SECRET_KEY=change-me
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change-me
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Visitor Management System
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_VALIDATE_CERTS=true
OTP_TTL_MINUTES=10
REGISTRATION_TOKEN_TTL_MINUTES=15
QR_TOKEN_TTL_HOURS=168
OTP_MAX_ATTEMPTS=5
FACE_MATCH_THRESHOLD=0.35
FACE_DUPLICATE_THRESHOLD=0.6
NAME_DUPLICATE_THRESHOLD=0.88
PHONE_DUPLICATE_THRESHOLD=0.75

# Admin API key used to protect admin endpoints (e.g., /admin/* and /identify).
ADMIN_API_KEY=change-me

# WARNING: NEXT_PUBLIC_ADMIN_API_KEY is exposed client-side. For production, use server-side auth or proxying.
NEXT_PUBLIC_ADMIN_API_KEY=change-me
